{
  "name": "b2c-store-backend",
  "version": "1.0.0",
  "description": "Full-stack B2C Store application with Express API and React frontend",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "dev:client": "vite --host 0.0.0.0 --config client/vite.config.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:client\"",
    "start": "node src/index.js",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "test:e2e": "playwright test",
    "build": "vite build --config client/vite.config.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "docs": "node src/docs/swagger.js"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.10.0",
    "supertest": "^6.3.4",
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.1.4",
    "@playwright/test": "^1.42.1",
    "concurrently": "^8.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "globalSetup": "./tests/setup.js",
    "globalTeardown": "./tests/teardown.js"
  }
}
